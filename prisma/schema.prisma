// ================================================================
// EngeServ Inspector - Schema do banco de dados (Sprint 1)
// Regra do PROJECT_RULES.md: "Todo documento devera ser gerado a
// partir do banco de dados". Este schema e o coracao do sistema.
// ================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN_MASTER
  GESTOR
  FUNCIONARIO
}

enum InspectionStatus {
  EM_ANDAMENTO
  AGUARDANDO_APROVACAO
  APROVADA
  REJEITADA
}

enum PhotoCategory {
  PLACA
  CORROSAO
  VALVULA
  MANOMETRO
  ULTRASSOM
  VISTA_GERAL
  SOLDA
  TRINCA
  REPARO
}

enum EquipmentType {
  CALDEIRA
  VASO_DE_PRESSAO
  SILO
  TANQUE
  TUBULACAO
  COMPRESSOR
  TROCADOR_DE_CALOR
  REATOR
  OUTRO
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  phone        String?  // WhatsApp do usuário
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById  String?
  createdBy    User?    @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers User[]   @relation("UserCreatedBy")

  clients Client[] @relation("ClientResponsible")

  inspectionsInspected  Inspection[] @relation("InspectionInspector")
  inspectionsApproved   Inspection[] @relation("InspectionApprover")
  inspectionPhotos      InspectionPhoto[] @relation("InspectionPhotoUploader")

  @@map("users")
}

model Client {
  id           String   @id @default(cuid())
  companyName  String
  cnpj         String?
  address      String?
  contactName  String?
  contactPhone String?
  contactEmail String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  responsibleId String?
  responsible   User?   @relation("ClientResponsible", fields: [responsibleId], references: [id])

  equipments Equipment[]

  @@map("clients")
}

model Equipment {
  id         String        @id @default(cuid())
  tag        String // identificacao/TAG do equipamento no cliente
  type       EquipmentType
  description String?
  manufacturer String?
  manufactureYear Int?
  // Dados de projeto basicos (o motor de calculo NR13 usara isso na Sprint 4)
  designPressureBar Float?
  originalThicknessMm Float? // espessura nominal do CASCO (nao dos tampos)
  minThicknessMm      Float? // limite de seguranca (> 2,5 mm conforme regra de negocio)
  // --- Novos campos (Sprint 3 - modelagem de dados para laudo) ---
  serialNumber String?
  designCode String?              // ex: "ASME SEC.VIII div.I/2021"
  designTempC Float?
  operatingPressureBar Float?     // pressao de operacao - DIFERENTE da PMTA
  operatingTempC Float?
  mawpBar Float?                  // PMTA - pressao maxima de trabalho admissivel
  hydroTestPressureBar Float?     // PTH
  headType String?                // ex: "Semieliptico", "Semiesferico", "Torisferico"
  headMaterial String?            // ex: "SA-36"
  bodyMaterial String?            // material do corpo/casco
  headNominalThicknessMm Float?   // DIFERENTE de originalThicknessMm (que e do casco)
  volumeLiters Float?
  jointEfficiency Float?          // eficiencia de solda, ex: 0.7
  fluidType String?               // ex: "Ar Comprimido"
  fluidClass String?              // Classe do fluido (A/B/C/D) - manual por enquanto
  riskGroup Int?                  // Grupo de potencial de risco - manual por enquanto
  nr13Category String?            // Categoria (I a V) - manual por enquanto
  // ----------------------------------------------------------------

  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  inspections Inspection[]

  @@unique([clientId, tag])
  @@map("equipments")
}

model TextTemplate {
  id        String   @id @default(cuid())
  code      String   @unique // ex: "REC_12_1", "REC_12_2" ...
  title     String   // ex: "12.1 - Inspecao visual anual"
  content   String   // texto completo da recomendacao
  category  String?  // ex: "RECOMENDACAO" | "AVISO" | "CONCLUSAO" | "AVISO_REPARO"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("text_templates")
}

model Inspection {
  id          String   @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  inspectorId String
  inspector   User @relation("InspectionInspector", fields: [inspectorId], references: [id])

  status      InspectionStatus @default(EM_ANDAMENTO)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  approvedAt  DateTime?
  approvedById String?
  approvedBy   User? @relation("InspectionApprover", fields: [approvedById], references: [id])
  rejectionReason String?

  photos      InspectionPhoto[]
  measurements InspectionMeasurement[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("inspections")
}

model InspectionPhoto {
  id           String   @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  url          String
  category     PhotoCategory
  caption      String?
  order        Int      @default(0)

  uploadedById String
  uploadedBy   User @relation("InspectionPhotoUploader", fields: [uploadedById], references: [id])

  createdAt    DateTime @default(now())

  @@map("inspection_photos")
}

model InspectionMeasurement {
  id           String   @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  point        String   // identificação do ponto (ex: "P1", "A-1")
  thicknessMm  Float    // espessura medida em mm
  angleDeg     Int?     // ângulo do ponto (se aplicável)
  notes        String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("inspection_measurements")
}